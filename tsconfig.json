{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "declaration": false,
      "sourceMap": true,
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "baseUrl": ".",
      "paths": {
        "@core/*": ["src/core/*"]
      }
    },
    "include": [
      "src/core/**/*.ts",
      "src/svelte-app/**/*.ts",
      "src/svelte-app/**/*.svelte"
    ]
  }